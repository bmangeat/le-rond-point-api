# Base de données
# Dev local (Docker, voir docker-compose.yml) :
DATABASE_URL="postgresql://lrp:lrp@localhost:5432/le_rond_point"
DIRECT_URL="postgresql://lrp:lrp@localhost:5432/le_rond_point"
# Neon (prod/QA) : utilise DATABASE_URL (pooled) + DIRECT_URL (directe pour les migrations)
# DATABASE_URL="postgresql://user:password@host/db?sslmode=require&pgbouncer=true"
# DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# Auth JWT
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-too-in-production"

# Google OAuth — depuis Google Cloud Console
# Pour le mobile : l'appli envoie l'idToken Google → vérifié côté serveur
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"

# Push notifications (VAPID)
VAPID_SUBJECT="mailto:contact@example.com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY="BL..."
VAPID_PRIVATE_KEY="..."

# Vercel Blob (photos)
BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# Email (Resend — optionnel, no-op si absent)
RESEND_API_KEY=""
RESEND_FROM="Le Rond Point <noreply@example.com>"

# URL de l'appli (pour les liens dans les invitations)
APP_URL="http://localhost:3000"

# CORS — origines autorisées (séparées par des virgules)
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8081"

# Port API
PORT=3001

# Cron — secret protégeant GET /api/cron/daily (Vercel Cron envoie
# `Authorization: Bearer <CRON_SECRET>`). Laisser vide en local = endpoint ouvert.
CRON_SECRET=""
