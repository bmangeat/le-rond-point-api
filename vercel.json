{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "nest build",
  "git": {
    "deploymentEnabled": {
      "main": false
    }
  },
  "functions": {
    "api/index.ts": {
      "includeFiles": "dist/**",
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ],
  "crons": [
    { "path": "/api/cron/daily", "schedule": "0 7 * * *" }
  ]
}
