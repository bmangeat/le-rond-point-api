meta {
  name: Refresh Token
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/auth/refresh
  body: json
  auth: none
}

body:json {
  {
    "refreshToken": "{{refreshToken}}"
  }
}

docs {
  Renouvelle l'accessToken (valable 15min) avec le refreshToken (valable 30j).
  Retourne { accessToken, refreshToken }.
}
